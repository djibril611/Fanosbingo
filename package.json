{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "stress:generate": "cd stress-test && npx tsx generate-test-users.ts",
    "stress:cleanup": "cd stress-test && npx tsx cleanup-test-data.ts",
    "stress:monitor": "cd stress-test && npx tsx monitor-database.ts",
    "stress:analyze": "cd stress-test && npx tsx analyze-results.ts",
    "stress:spike": "cd stress-test && ./run-test.sh spike",
    "stress:sustained": "cd stress-test && ./run-test.sh sustained",
    "stress:gradual": "cd stress-test && ./run-test.sh gradual",
    "stress:all": "cd stress-test && ./run-test.sh all",
    "stress:full-suite": "cd stress-test && ./full-test-suite.sh"
  },
  "dependencies": {
    "@reown/appkit": "^1.8.17",
    "@reown/appkit-adapter-wagmi": "^1.8.17",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-query": "^5.90.20",
    "@twa-dev/sdk": "^8.0.2",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.45.2",
    "wagmi": "^3.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "dotenv": "^17.2.3",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "k6": "^0.0.0",
    "postcss": "^8.4.35",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^3.4.1",
    "terser": "^5.44.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-compression": "^0.5.1"
  }
